FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string

# Database — Railway provides this automatically in production
DATABASE_URL=postgresql://user:password@localhost:5432/cis_platform

# Anthropic API (for AI agents)
ANTHROPIC_API_KEY=your-key-here

# 1C OData (add when you get credentials)
ODATA_URL=http://your-1c-server/base/odata/standard.odata/
ODATA_USER=readonly_user
ODATA_PASS=readonly_password
