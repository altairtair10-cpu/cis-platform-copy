+++ b/app/templates/documents/_dlog_style.html
@@ -0,0 +1,37 @@
+{# Documentolog-style shared form styles — used by trebovanie / po_services forms #}
+<style>
+.dlg-h{font-size:13px;font-weight:600;color:#2563eb;border-bottom:2px solid #2563eb;padding-bottom:6px;margin:26px 0 18px;display:flex;align-items:center;justify-content:space-between}
+.dlg-h:first-of-type{margin-top:0}
+.dlg-title{font-size:16px;font-weight:600;color:#2563eb;text-transform:uppercase;letter-spacing:.01em}
+.dlg-row{display:grid;grid-template-columns:170px 1fr;gap:6px 14px;align-items:start;margin-bottom:13px}
+.dlg-label{font-size:12px;color:var(--text-2);padding-top:8px;line-height:1.4}
+.dlg-req{color:#C0392B;margin-left:2px}
+.dlg-input,.dlg-select,.dlg-textarea{width:100%;background:var(--bg-input,#f7f8fa);border:1px solid var(--border);border-radius:6px;padding:7px 10px;font-size:12px;color:var(--text-1);font-family:inherit;outline:none;box-sizing:border-box}
+.dlg-textarea{resize:vertical;min-height:56px}
+.dlg-input:focus,.dlg-select:focus,.dlg-textarea:focus{border-color:#2563eb}
+.dlg-static{font-size:12px;color:var(--text-1);padding-top:8px}
+.dlg-picker{display:flex;align-items:center;gap:8px;background:var(--bg-input,#f7f8fa);border:1px solid var(--border);border-radius:6px;padding:7px 10px;min-height:20px;cursor:pointer}
+.dlg-picker:hover{border-color:#2563eb}
+.dlg-picker .ti{margin-left:auto;color:var(--text-3);font-size:15px}
+.dlg-picker-ph{font-size:12px;color:var(--text-3)}
+.dlg-chips{display:flex;flex-direction:column;gap:6px;margin-top:6px}
+.dlg-chip{display:flex;align-items:center;gap:8px;background:#fff;border:1px solid var(--border);border-radius:6px;padding:6px 10px;font-size:12px;color:var(--text-1);max-width:440px;box-shadow:0 1px 2px rgba(0,0,0,.05)}
+.dlg-chip .ti-menu-2{color:var(--text-3);font-size:13px;flex-shrink:0}
+.dlg-chip-name{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
+.dlg-chip-x{background:none;border:none;color:var(--text-3);cursor:pointer;font-size:15px;line-height:1;margin-left:auto;padding:0 2px;font-family:inherit}
+.dlg-chip-x:hover{color:#C0392B}
+.dlg-textbtn{background:none;border:none;font-size:11px;font-weight:600;letter-spacing:.05em;color:var(--text-2);cursor:pointer;font-family:inherit;padding:0;text-transform:uppercase}
+.dlg-textbtn:hover{color:#2563eb}
+.dlg-stage{display:grid;grid-template-columns:16px 16px 210px 1fr 20px;gap:10px;align-items:start;margin-bottom:14px}
+.dlg-stage .ti-menu-2{color:var(--text-3);font-size:14px;margin-top:9px}
+.dlg-stage-num{font-size:12px;color:var(--text-2);margin-top:9px;text-align:center}
+.dlg-steps{display:flex;margin:14px 0 10px}
+.dlg-step{background:#eef1f5;color:var(--text-2);font-size:12px;font-weight:500;padding:7px 20px 7px 28px;clip-path:polygon(0 0,calc(100% - 14px) 0,100% 50%,calc(100% - 14px) 100%,0 100%,14px 50%);margin-left:-8px}
+.dlg-step:first-child{clip-path:polygon(0 0,calc(100% - 14px) 0,100% 50%,calc(100% - 14px) 100%,0 100%);margin-left:0;padding-left:20px}
+.dlg-step.active{background:#2563eb;color:#fff}
+.dlg-step.done{background:#dbe7fb;color:#2563eb}
+.dlg-upl{display:inline-flex;align-items:center;gap:7px;background:#fff;border:1px solid var(--border);border-radius:6px;padding:7px 18px;font-size:12px;font-weight:500;color:var(--text-1);cursor:pointer}
+.dlg-upl:hover{border-color:#2563eb;color:#2563eb}
+.dlg-cols{display:grid;grid-template-columns:1fr 1fr;gap:20px 48px;align-items:start}
+@media(max-width:980px){.dlg-cols{grid-template-columns:1fr}}
+</style>
