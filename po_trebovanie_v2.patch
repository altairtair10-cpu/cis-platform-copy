+function addItemRow(){
+  const tbody = document.getElementById('items-body');
+  const tr = document.createElement('tr');
+  tr.innerHTML = `
+    <td style="padding:6px;text-align:center;border-bottom:1px solid var(--border)"><span class="dlg-drag">≡</span></td>
+    <td style="padding:6px;border-bottom:1px solid var(--border)"><textarea name="item_name[]" rows="2" required style="width:100%;background:transparent;border:none;font-size:11px;color:var(--text-1);font-family:inherit;resize:none;outline:none"></textarea></td>
